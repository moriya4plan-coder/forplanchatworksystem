{
  "manifest_version": 3,
  "name": "Chatwork 一括既読 | フォープラン",
  "version": "2.0.2",
  "description": "Chatwork公式APIを使って全ルームを一括既読にします",
  "update_url": "https://raw.githubusercontent.com/moriya4plan-coder/forplanchatworksystem/main/update.xml",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.chatwork.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
